
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil del usuario con su rol y jornadas asignadas.",
      "properties": {
        "id": { "type": "string" },
        "firebaseAuthUid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "coordinator", "teacher"] },
        "shiftIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "IDs de las jornadas asignadas" 
        },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName", "role"]
    },
    "Shift": {
      "title": "Shift",
      "type": "object",
      "description": "Define un horario o jornada laboral (Ej: Matutina, Vespertina).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Nombre de la jornada (Ej: Turno Mañana)" },
        "startTime": { "type": "string", "description": "Hora de entrada (HH:mm)" },
        "endTime": { "type": "string", "description": "Hora de salida (HH:mm)" },
        "tolerance": { "type": "number", "description": "Minutos de tolerancia para la entrada" }
      },
      "required": ["id", "name", "startTime", "endTime"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/shifts/{shiftId}",
        "definition": {
          "entityName": "Shift",
          "description": "Catálogo de jornadas laborales disponibles."
        }
      },
      {
        "path": "/userProfiles/{uid}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Perfiles de usuario."
        }
      }
    ]
  }
}
