
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)); }
    function isCoordinator() { return isSignedIn() && exists(/databases/$(database)/documents/roles_coordinators/$(request.auth.uid)); }
    function isPrivileged() { return isAdmin() || isCoordinator(); }

    match /userProfiles/{userId} {
      allow read: if isPrivileged() || request.auth.uid == userId;
      allow write: if isPrivileged();
    }

    match /roles_admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    match /roles_coordinators/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /userProfiles/{userId}/attendanceRecords/{recordId} {
      allow read: if isPrivileged() || request.auth.uid == userId;
      allow write: if isPrivileged() || request.auth.uid == userId;
    }
  }
}
