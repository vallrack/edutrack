rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    function getUserRole() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    function isCoordinator() {
      return isSignedIn() && getUserRole() == 'coordinator';
    }
    function isPrivileged() {
      return isAdmin() || isCoordinator();
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow read: if isPrivileged() || isOwner(userId);
      allow create: if isPrivileged() || isOwner(userId);
      allow update: if isPrivileged() || (isOwner(userId) && (request.resource.data.role == resource.data.role || !('role' in request.resource.data)));
      allow delete: if isAdmin();

      match /attendanceRecords/{recordId} {
        allow read: if isPrivileged() || isOwner(userId);
        allow create, update: if isPrivileged() || isOwner(userId);
        allow delete: if isAdmin();
      }
    }

    match /roles_admins/{userId} {
      allow read: if isPrivileged();
      allow write: if isAdmin();
    }

    match /roles_coordinators/{userId} {
      allow read: if isPrivileged();
      allow write: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /globalAttendanceRecords/{recordId} {
      allow read: if isPrivileged();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}