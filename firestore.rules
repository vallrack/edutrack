
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)); }
    function isCoordinator() { return isSignedIn() && exists(/databases/$(database)/documents/roles_coordinators/$(request.auth.uid)); }
    function isPrivileged() { return isAdmin() || isCoordinator(); }

    match /userProfiles/{userId} {
      allow read: if isPrivileged() || request.auth.uid == userId;
      // Permite crear si es admin o si el usuario se está registrando a sí mismo
      allow create: if isPrivileged() || (isSignedIn() && request.auth.uid == userId);
      // Permite actualizar si es admin/coord o si el usuario edita su propio perfil (sin cambiar su rol)
      allow update: if isPrivileged() || (isSignedIn() && request.auth.uid == userId && (request.resource.data.role == resource.data.role || !('role' in request.resource.data)));
      // Permite eliminar solo a administradores
      allow delete: if isAdmin();
    }

    match /roles_admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && !exists(/databases/$(database)/documents/roles_admins/$(userId));
      allow update, delete: if isAdmin();
    }

    match /roles_coordinators/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if isPrivileged();
    }

    match /userProfiles/{userId}/attendanceRecords/{recordId} {
      allow read: if isPrivileged() || request.auth.uid == userId;
      allow write: if isPrivileged() || request.auth.uid == userId;
    }
  }
}
